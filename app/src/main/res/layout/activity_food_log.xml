<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/food"
    android:gravity="center">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="604dp"
        android:background="#AA000000"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="#FBEFFA"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="0dp"
                android:layout_marginTop="5dp"
                android:contentDescription="Back Button"
                android:padding="8dp"
                android:src="@drawable/arrow" />

            <TextView
                android:id="@+id/dateText"
                android:layout_width="124dp"
                android:layout_height="33dp"
                android:layout_marginTop="9dp"
                android:text="Food Log"
                android:textColor="#000000"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/breakfastButton"
            android:layout_width="277dp"
            android:layout_height="41dp"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:background="#FBEFFA"
            android:text="Add Breakfast" />

        <Button
            android:id="@+id/lunchButton"
            android:layout_width="277dp"
            android:layout_height="41dp"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:background="#FBEFFA"
            android:text="Add Lunch" />

        <Button
            android:id="@+id/snackButton"
            android:layout_width="277dp"
            android:layout_height="41dp"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:background="#FBEFFA"
            android:text="Add Snack" />

        <Button
            android:id="@+id/dinnerButton"
            android:layout_width="277dp"
            android:layout_height="41dp"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:background="#FBEFFA"
            android:text="Add Dinner" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="259dp"
            android:background="#FBEFFA"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="#FBEFFA"
                android:text="Foods Logged"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/foodList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FBEFFA"
                />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>